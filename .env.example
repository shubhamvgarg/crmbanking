# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=sqlite:///db.sqlite3

# Email (console backend used when DEBUG=True)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@crmbank.local

# Groq LLM (Phase 3+)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# RabbitMQ — online service (Phase 5+)
RABBITMQ_URL=amqps://user:password@your-host.rmq.cloud.amqp.net/vhost
RABBITMQ_QUEUE=whatsapp.messages
RABBITMQ_EXCHANGE=crm.outreach

# Twilio WhatsApp (Phase 6+)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Agent Pipeline (Phase 3+)
AGENT_BATCH_SIZE=100
ML_MODEL_PATH=models/loan_conversion_model.pkl
DEFAULT_DECISION_METHOD=rule_based
